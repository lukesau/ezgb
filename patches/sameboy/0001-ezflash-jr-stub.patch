@@ -0,0 +1,73 @@
+#pragma once
+#include "defs.h"
+#include <stdbool.h>
+#include <stdint.h>
+#include <stddef.h>
+
+/* EZ Flash Jr FPGA stub for reverse-engineering the kernel in-emulator.
+ *
+ * Stage 0: title detect, $7Fxx logging, battery $A201 magic, SD-init soft-patch.
+ * Stage 1: host-backed SD image (sd/card.img) served through the $A000 window.
+ * Stage 2: RTC page via $7FC0=$06, BCD registers at $A008-$A00E.
+ * Stage 3: cart SRAM banks via $7FC0=$03 (file-list / status cache),
+ *          FW version via $7FC0=$04, ROM-load status via $7F36.
+ * Stage 4: $7FE0 boot — game keeps the same cart_sram backing store (like hardware).
+ * Stage 5: FRAM on disk (sd/fram.bin) for power-cycle; host .sav suppressed;
+ *          kernel BACKUPSAVE dumps FRAM to SAVER on next boot after [A]OK.
+ *
+ * Protocol details cross-checked with daid/ezflashjr doc/Protocol.md.
+ */
+
+enum {
+    EZJR_SRAM_BANKS = 64,
+    EZJR_SRAM_BANK_SIZE = 0x2000, /* $A000-$BFFF */
+};
+
+typedef struct {
+    bool enabled;
+    bool log;
+    bool status_window;
+    /* After $7FE0: ROM runs but cart_sram/img stay alive (mbc_ram aliases cart_sram). */
+    bool game_mode;
+    bool mbc_ram_is_cart_sram;
+    bool fram_dirty; /* host-side FRAM image needs flush (battery-backed SRAM) */
+    char fram_path[1024];
+    uint8_t unlock_step;
+    uint8_t rom_latch; /* $4000: SRAM page while $7FC0=$03 */
+    uint8_t status_byte;
+    uint16_t last_cmd_addr;
+    uint8_t last_cmd_value;
+    uint8_t sd_regs[5];   /* $7FB0-$7FB4: LBA0..3 + count (+bit7=write) */
+    uint8_t bank_regs[5]; /* $7FC0-$7FC4; [0] is FPGA page select */
+    uint8_t sd_ctrl;      /* last $7F30 value (0=off, 1=enable, 3=read start) */
+    uint8_t sd_buf[2048]; /* FPGA window: up to 4 * 512 bytes at $A000 */
+    uint8_t *img;
+    size_t img_size;
+    bool img_dirty;
+    char img_path[1024];
+    /* BCD RTC mirror for page $06: indices 0..6 <=> $A008..$A00E */
+    uint8_t rtc[7];
+    /* 64 * 8KB FPGA cart SRAM ($7FC0=$03). Page $11 = status, $12+ = file list.
+     * Banks 0..N are the same physical SRAM a launched game sees (battery). */
+    uint8_t *cart_sram;
+    uint8_t fw_version;   /* any $Axxx byte while $7FC0=$04 */
+    uint8_t load_ctrl;    /* last $7F36 value */
+    uint8_t load_cmd[512];
+    bool load_done;
+    uint8_t mbc_type;     /* last $7F37 value */
+    /* Built on $7F36=$03; applied (+ GB_reset) after next GB_run on $7FE0=$80. */
+    uint8_t *pending_rom;
+    size_t pending_rom_size;
+    bool pending_boot;
+} GB_ezflash_jr_t;
+
+#ifdef GB_INTERNAL
+internal void GB_ezflash_jr_configure(GB_gameboy_t *gb);
+internal void GB_ezflash_jr_cleanup(GB_gameboy_t *gb);
+/* Returns true if the write was consumed by the FPGA stub (do not pass to MBC). */
+internal bool GB_ezflash_jr_write(GB_gameboy_t *gb, uint16_t addr, uint8_t value);
+/* Returns true if *out was filled by the stub. */
+internal bool GB_ezflash_jr_read(GB_gameboy_t *gb, uint16_t addr, uint8_t *out);
+/* Call after GB_clear_running_thread in GB_run — applies pending ROM boot/reset. */
+internal void GB_ezflash_jr_post_run(GB_gameboy_t *gb);
+#endif
