.DS_Store

# Python bytecode
__pycache__/
*.py[cod]

# EZ Flash's copyrighted firmware binaries, not our work, keep local-only
/ezgb.dat
/juniorkernel-1.04e-FW4/
/juniorkernel-1.05e-FW5/
re/*/kernel.gb

# cloned reference tools (mgbdis, omega-de-kernel, SameBoy), not our code
tools/

# build artifacts from `make` inside re/*/disassembly
re/*/disassembly/game.gb
re/*/disassembly/game_trunc.gb
re/*/disassembly/game.o
re/*/disassembly/game.map
re/*/disassembly/game.sym
# Symlink created by scripts/run-sameboy-debug.sh (points at game.sym)
re/*/kernel.sym

# Debugger auto-trace output
scripts/debug/*.log

# Ephemeral propose-labels / packet output
re/*/label-proposals.txt

# Local microSD for the SameBoy EZ Jr FPGA stub.
# ROMs, saves, and raw card images are copyrighted / personal — stay out of git.
/sd/**
!/sd/README.md

